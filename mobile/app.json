{
  "expo": {
    "name": "Grace Pad",
    "slug": "grace-pad",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "gracepad",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#160A47"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gracepad.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Used for authentication"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#160A47"
      },
      "package": "com.gracepad.app"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
